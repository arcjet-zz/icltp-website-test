---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import { withBase } from '../utils/url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'ICLTP 2027 — International Conference on Low Temperature Plasmas',
  description = 'Join the global low temperature plasma community in Beijing, April 19–23, 2027.',
  image = '/assets/images/67ca557ad9-fd941709d8997ce3900bb54587faf18f.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: '1st International Conference on Low Temperature Plasmas',
  alternateName: 'ICLTP 2027',
  startDate: '2027-04-19',
  endDate: '2027-04-23',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: 'Vision Plaza Shahe Bailing',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Beijing',
      addressCountry: 'CN',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Chinese Society of Theoretical and Applied Mechanics',
  },
  url: new URL(withBase('/'), Astro.site).toString(),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#111d35" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(withBase(image), Astro.site)} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
  </body>
</html>
