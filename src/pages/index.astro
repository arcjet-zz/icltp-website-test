---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import { deadlines, speakers } from '../data/site';
import { withBase } from '../utils/url';
import beijingImage from '../assets/beijing.jpg';

const arrow = `<svg aria-hidden="true" viewBox="0 0 20 20"><path d="M5 15 15 5M7 5h8v8"/></svg>`;

const topicGroups = [
  {
    number: '01',
    title: 'Fundamentals & methods',
    topics: ['Fundamental plasma science', 'Plasma diagnostics', 'Modelling and simulation'],
  },
  {
    number: '02',
    title: 'Sources & systems',
    topics: ['Radio-frequency plasmas', 'Atmospheric microplasmas', 'Magnetized plasmas', 'DC, AC and other sources'],
  },
  {
    number: '03',
    title: 'Processes & applications',
    topics: ['Semiconductor processing', 'Gas conversion and catalysis', 'Biomedical and liquid interactions', 'Propulsion and agriculture'],
  },
];

const formats = [
  ['Plenary lectures', 'Broad perspectives from established researchers'],
  ['Invited & contributed talks', 'Focused results across fourteen scientific topics'],
  ['Poster sessions', 'Dedicated time for detailed technical exchange'],
  ['Student program', 'Travel support and presentation awards'],
];
---

<BaseLayout
  title="ICLTP 2027 — International Conference on Low Temperature Plasmas"
  description="The 1st International Conference on Low Temperature Plasmas, 19–23 April 2027 in Beijing, China."
>
  <section class="home-hero">
    <div class="shell home-hero-grid">
      <div class="home-hero-copy">
        <p class="home-kicker">19–23 April 2027 · Beijing, China</p>
        <h1>The 1st International Conference on <em>Low Temperature Plasmas</em></h1>
        <p class="home-hero-summary">
          An international scientific meeting covering the foundations, diagnostics, modeling, sources
          and applications of low-temperature plasmas.
        </p>
        <div class="home-hero-actions">
          <a class="button home-button-primary" href={withBase('/registration/')}>
            Registration information
            <Fragment set:html={arrow} />
          </a>
          <a class="home-inline-link" href={withBase('/abstract-submission/')}>
            Abstract submission <span aria-hidden="true">→</span>
          </a>
        </div>
        <p class="home-status">
          <span>Current status</span>
          Registration opens 1 August 2026. Abstract submission opens 1 September 2026.
        </p>
      </div>

      <div class="home-hero-carousel">
        <HeroCarousel />
      </div>
    </div>

    <div class="shell home-fact-grid" aria-label="Conference facts">
      <div><span>Dates</span><strong>19–23 April 2027</strong></div>
      <div><span>Location</span><strong>Beijing, China</strong></div>
      <div><span>Scientific scope</span><strong>14 topics</strong></div>
      <div><span>Meeting format</span><strong>In person</strong></div>
    </div>
  </section>

  <section class="home-section home-overview" id="about">
    <div class="shell home-overview-grid">
      <header class="home-section-intro">
        <p class="home-kicker">About the meeting</p>
        <h2>A forum for low-temperature plasma research.</h2>
      </header>
      <div class="home-overview-copy">
        <p class="home-lead">
          ICLTP 2027 brings together researchers, engineers and students working from fundamental
          plasma physics to industrial, biomedical, energy and environmental applications.
        </p>
        <p>
          The program is designed for technical exchange across disciplines, with plenary lectures,
          contributed presentations, poster sessions and dedicated support for student participation.
        </p>
      </div>
      <dl class="home-format-list">
        {formats.map(([title, description], index) => (
          <div>
            <dt><span>{String(index + 1).padStart(2, '0')}</span>{title}</dt>
            <dd>{description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="home-section home-dates" id="important-dates">
    <div class="shell">
      <div class="home-section-heading">
        <div>
          <p class="home-kicker home-kicker-light">Participation timeline</p>
          <h2>Important dates</h2>
        </div>
        <p>All dates use China Standard Time (UTC+8). Any changes will be published on the relevant information page.</p>
      </div>
      <div class="home-date-list">
        {deadlines.map((item, index) => (
          <div>
            <span class="home-date-index">{String(index + 1).padStart(2, '0')}</span>
            <time datetime={`${item.year}-${item.date.startsWith('Sep') ? '09-01' : item.date.startsWith('Dec') ? '12-01' : item.date.startsWith('Feb') ? '02-01' : '03-01'}`}>
              <strong>{item.date}</strong>
              <span>{item.year}</span>
            </time>
            <span class="home-date-label">{item.label}</span>
          </div>
        ))}
      </div>
      <a class="home-inline-link home-inline-link-light" href={withBase('/abstract-submission/')}>
        Read the submission guidance <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="home-section home-science">
    <div class="shell">
      <div class="home-section-heading home-section-heading-dark">
        <div>
          <p class="home-kicker">Scientific scope</p>
          <h2>Fourteen topics across the research continuum.</h2>
        </div>
        <p>
          The scope connects fundamental processes and experimental methods with plasma sources,
          materials, energy, health and environmental applications.
        </p>
      </div>
      <div class="home-topic-grid">
        {topicGroups.map((group) => (
          <article>
            <span>{group.number}</span>
            <h3>{group.title}</h3>
            <ul>
              {group.topics.map((topic) => <li>{topic}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <a class="home-wide-link" href={withBase('/topics/')}>
        <span>View all fourteen topic descriptions</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="home-section home-speakers">
    <div class="shell">
      <div class="home-section-heading home-section-heading-dark">
        <div>
          <p class="home-kicker">Scientific program</p>
          <h2>Confirmed plenary speakers</h2>
        </div>
        <a class="home-inline-link" href={withBase('/speakers/')}>Speaker details <span aria-hidden="true">→</span></a>
      </div>
      <div class="home-speaker-marquee" aria-label="Confirmed plenary speakers. Animation pauses on hover or keyboard focus.">
        <div class="home-speaker-track">
          <div class="home-speaker-group" aria-hidden="true">
            {speakers.map((speaker, index) => (
              <article class="home-speaker-card">
                <a href={withBase('/speakers/')} tabindex="-1">
                  <div class="home-speaker-photo">
                    <img src={withBase(speaker.image)} alt="" width="480" height="360" loading="lazy" />
                    <span class="home-speaker-index">{String(index + 1).padStart(2, '0')}</span>
                  </div>
                  <div class="home-speaker-copy">
                    <span class="home-speaker-role">{speaker.role}</span>
                    <h3>{speaker.name}</h3>
                    <p class="home-speaker-affiliation">{speaker.affiliation}</p>
                    <p class="home-speaker-subject">{speaker.title}</p>
                    <span class="home-speaker-link">Speaker profile <b aria-hidden="true">→</b></span>
                  </div>
                </a>
              </article>
            ))}
          </div>
          <div class="home-speaker-group">
            {speakers.map((speaker, index) => (
              <article class="home-speaker-card">
                <a href={withBase('/speakers/')} aria-label={`Read about ${speaker.name}`}>
                  <div class="home-speaker-photo">
                    <img src={withBase(speaker.image)} alt="" width="480" height="360" loading="lazy" />
                    <span class="home-speaker-index">{String(index + 1).padStart(2, '0')}</span>
                  </div>
                  <div class="home-speaker-copy">
                    <span class="home-speaker-role">{speaker.role}</span>
                    <h3>{speaker.name}</h3>
                    <p class="home-speaker-affiliation">{speaker.affiliation}</p>
                    <p class="home-speaker-subject">{speaker.title}</p>
                    <span class="home-speaker-link">Speaker profile <b aria-hidden="true">→</b></span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-visit">
    <div class="shell home-visit-grid">
      <figure>
        <Image
          src={beijingImage}
          alt="The Forbidden City Corner Tower reflected in its moat beneath an evening sky"
          widths={[640, 900, 1200]}
          sizes="(max-width: 900px) 100vw, 48vw"
          loading="lazy"
        />
        <figcaption>Forbidden City Corner Tower · Beijing</figcaption>
      </figure>
      <div class="home-visit-copy">
        <p class="home-kicker">Plan your visit</p>
        <h2>Practical information for Beijing</h2>
        <p>
          The venue is in Beijing’s Changping District. Travel, accommodation and visa guidance are
          maintained as separate reference pages so participants can find current details quickly.
        </p>
        <nav aria-label="Visitor information">
          <a href={withBase('/venue/')}><span>Venue & transport</span><span aria-hidden="true">→</span></a>
          <a href={withBase('/lodging/')}><span>Accommodation</span><span aria-hidden="true">→</span></a>
          <a href={withBase('/visa/')}><span>Visa information</span><span aria-hidden="true">→</span></a>
          <a href={withBase('/tours/')}><span>About Beijing</span><span aria-hidden="true">→</span></a>
        </nav>
      </div>
    </div>
  </section>

  <section class="home-section home-organization">
    <div class="shell home-organization-grid">
      <header>
        <p class="home-kicker">Organization</p>
        <h2>Convened by the plasma science community.</h2>
      </header>
      <dl>
        <div>
          <dt>Guiding unit</dt>
          <dd>Plasma Science and Technology Committee of the Chinese Society of Theoretical and Applied Mechanics</dd>
        </div>
        <div>
          <dt>Organizer</dt>
          <dd>Chinese Society of Theoretical and Applied Mechanics</dd>
        </div>
        <div>
          <dt>Supporting institutions</dt>
          <dd>Institute of Mechanics, Chinese Academy of Sciences · Beihang University · Tsinghua University</dd>
        </div>
      </dl>
      <aside>
        <span>Conference enquiries</span>
        <a href="mailto:tianshengwei@buaa.edu.cn">tianshengwei@buaa.edu.cn</a>
        <a href="mailto:20375069@buaa.edu.cn">20375069@buaa.edu.cn</a>
        <a class="home-inline-link" href={withBase('/contact/')}>Full contact directory <span aria-hidden="true">→</span></a>
      </aside>
    </div>
  </section>

  <section class="home-actions">
    <div class="shell home-actions-grid">
      <div>
        <p class="home-kicker home-kicker-light">Participate in ICLTP 2027</p>
        <h2>Registration and abstract submission</h2>
        <p>Registration opens 1 August 2026. Abstract submission opens 1 September 2026.</p>
      </div>
      <div>
        <a class="button home-button-light" href={withBase('/registration/')}>Registration details <Fragment set:html={arrow} /></a>
        <a class="home-inline-link home-inline-link-light" href={withBase('/abstract-submission/')}>Submission requirements <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
